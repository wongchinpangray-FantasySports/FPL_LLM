# Supabase (used by both Python sync jobs and the Next.js app)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Next.js public Supabase (browser reads, RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Google Gemini LLM (free tier)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: rate limiting via Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated emails allowed to access /admin in the Next.js app
ADMIN_EMAILS=

# Next.js only: if fantasy.premierleague.com returns 403 for server-side FPL fetches
# (cloud/datacenter IPs), set to a current desktop Chrome User-Agent string.
# FPL_FETCH_USER_AGENT=

# Full browser Cookie while logged into fantasy.premierleague.com — enables /my-team/ (Pick Team parity).
# FPL_SESSION_COOKIE=

# Optional: calendar year when the FPL game season starts (e.g. 2026 for 2026/27).
# Overrides bootstrap-derived season for Python sync + Next.js DB queries if set.
# FPL_CURRENT_SEASON=
