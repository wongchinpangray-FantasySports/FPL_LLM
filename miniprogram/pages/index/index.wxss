.page {
  padding: 48rpx 40rpx 120rpx;
}

.dot-wrap {
  margin-bottom: 24rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #00ff87;
  box-shadow: 0 0 20rpx rgba(0, 255, 135, 0.6);
}

.brand {
  font-size: 44rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 0.02em;
  margin-bottom: 12rpx;
}

.eyebrow {
  font-size: 20rpx;
  letter-spacing: 0.25em;
  color: #00ff87;
  font-weight: 500;
  margin-bottom: 32rpx;
}

.title {
  font-size: 26rpx;
  color: #94a3b8;
  line-height: 1.5;
  margin-bottom: 48rpx;
}

.card {
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.label {
  font-size: 20rpx;
  color: #64748b;
  font-weight: 500;
  letter-spacing: 0.15em;
  margin-bottom: 16rpx;
}

.input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  background: rgba(0, 0, 0, 0.35);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #f1f5f9;
  font-size: 32rpx;
  margin-bottom: 24rpx;
}

.hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.hint.warn {
  color: #a8b0bd;
}

.accent {
  color: #00ff87;
  font-weight: 600;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  font-size: 28rpx;
  border-radius: 16rpx;
  padding: 8rpx 0;
  border: none;
  line-height: 2.2;
}

.btn::after {
  border: none;
}

.btn.primary {
  background: #00ff87;
  color: #0b0a0f;
  font-weight: 600;
  margin-top: 8rpx;
}

.btn.outline {
  background: rgba(0, 255, 135, 0.12);
  color: #e2e8f0;
  border: 1rpx solid rgba(0, 255, 135, 0.35);
}

.btn.outline:active {
  background: rgba(0, 255, 135, 0.2);
}
