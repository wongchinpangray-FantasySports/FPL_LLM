<view class="page">
  <view class="dot-wrap">
    <view class="dot" />
  </view>
  <view class="brand">FALEAGUE AI</view>
  <view class="eyebrow">FANTASY · AI</view>
  <view class="title">Fill your Entry ID to use Chat / Dashboard / Planner in the in-app browser.</view>

  <view class="card">
    <view class="label">ENTRY ID</view>
    <input
      class="input"
      type="number"
      placeholder="e.g. 1234567"
      value="{{entryInput}}"
      bindinput="onEntryInput"
    />
    <button class="btn primary" bindtap="onSave">Save & use below</button>
  </view>

  <view class="hint" wx:if="{{entryId}}">Current: <text class="accent">{{entryId}}</text> · data stored on this device only</view>
  <view class="hint warn" wx:else>No Entry ID yet — you can still open features; add ID on the web for your squad when prompted.</view>

  <view class="actions">
    <button class="btn outline" data-page="chat" bindtap="openWeb">Chat</button>
    <button class="btn outline" data-page="dashboard" bindtap="openWeb">Dashboard</button>
    <button class="btn outline" data-page="planner" bindtap="openWeb">Planner</button>
  </view>
</view>
