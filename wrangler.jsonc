{
	// Monorepo root: paths point into web/.open-next (created by `npm run build:cloudflare` in web/).
	// Keep worker name + flags aligned with web/wrangler.jsonc.
	"$schema": "./web/node_modules/wrangler/config-schema.json",
	"main": "web/.open-next/worker.js",
	"name": "fpl-llm-web",
	"compatibility_date": "2025-04-01",
	"compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
	"assets": {
		"directory": "web/.open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			"binding": "WORKER_SELF_REFERENCE",
			"service": "fpl-llm-web"
		}
	]
}
