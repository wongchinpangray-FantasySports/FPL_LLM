SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: canonical site URL for Supabase auth emails (e.g. https://www.faleague-ai.com)
# NEXT_PUBLIC_SITE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: Gemini TTS for WC match summary audio (defaults: gemini-2.5-flash-preview-tts, voices Algieba/en + Iapetus/zh)
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_VOICE_EN=Algieba
# GEMINI_TTS_VOICE_ZH=Iapetus
# Optional (Cloudflare Workers + Gemini): AI Gateway — easiest: set gateway NAME only (wrangler has `ai` binding `AI`)
# CLOUDFLARE_AI_GATEWAY_NAME=fpl-gemini
# GEMINI_AI_GATEWAY_TOKEN=   # if gateway is authenticated
# Or full URL instead of name:
# GEMINI_AI_GATEWAY_BASE_URL=https://gateway.ai.cloudflare.com/v1/{account_id}/{gateway_name}/google-ai-studio
# Or build URL from account + name:
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_GATEWAY_NAME=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Comma-separated emails allowed to access /admin (must match signed-in account)
ADMIN_EMAILS=

# (cloud/datacenter IPs), set to a current desktop Chrome User-Agent string.
# FPL_FETCH_USER_AGENT=

# Optional: legacy deploy-wide cookie for /my-team/ (ops only — not exposed in UI).
# FPL_SESSION_COOKIE=

# Optional: FPL season start year (e.g. 2026). Overrides fpl_meta for DB queries + sync.
# FPL_CURRENT_SEASON=
# Add the same keys as above in: Workers & Pages → fpl-llm-web → Settings → Variables
# or use: npx wrangler secret put NAME
