SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# If the official FPL API returns 403 from your host (common on cloud IPs e.g. Vercel),
# paste a current desktop Chrome User-Agent from your browser (DevTools → Network → request headers).
# FPL_FETCH_USER_AGENT=

# Optional: full `Cookie` header from your browser while logged in at fantasy.premierleague.com
# (e.g. pl_profile=...). Server-only. Makes sync use /api/my-team/ so it matches the Pick Team page.
# FPL_SESSION_COOKIE=
